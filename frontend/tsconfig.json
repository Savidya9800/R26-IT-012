{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,

    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,

    "jsx": "react-jsx",

    "strict": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    "ignoreDeprecations": "6.0"
  },
  "include": ["src"]
}